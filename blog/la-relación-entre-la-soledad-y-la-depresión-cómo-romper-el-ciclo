  var url = encodeURIComponent('https://mental.eutimya.org/blog/soledad-depresion');
  var text = encodeURIComponent('La relación entre la soledad y la depresión: cómo romper el ciclo — Eutimya');
  window.open('https://wa.me/?text=' + text + '%20' + url, '_blank');
}
function copyLink() {
  var url = 'https://mental.eutimya.org/blog/soledad-depresion';
  var btn = document.getElementById('copyBtn');
  function done() {
    btn.textContent = '✓ Enlace copiado';
    btn.classList.add('copied');
    setTimeout(function() { btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copiar enlace'; btn.classList.remove('copied'); }, 2500);
  }
  if (navigator.clipboard) { navigator.clipboard.writeText(url).then(done).catch(function() { done(); }); }
  else { done(); }
}
</script>
